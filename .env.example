# Server-only Supabase settings. Add these in Vercel; never prefix with NEXT_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_replace-with-your-server-only-secret-key
SUPABASE_ORDER_BUCKET=order-photos

# Order emails (server only). Verify birthdayherobook.com in Resend before using
# this sender address. On each paid order RESEND_API_KEY sends two emails, neither
# of which contains any children's details:
#   1. a staff alert to ORDER_NOTIFICATION_EMAIL, and
#   2. a confirmation to the purchaser.
# ORDER_NOTIFICATION_FROM is the sender for both; replies go to the contact inbox.
RESEND_API_KEY=re_replace-with-your-resend-api-key
ORDER_NOTIFICATION_FROM="Birthday Hero Book Orders <orders@birthdayherobook.com>"
ORDER_NOTIFICATION_EMAIL=hello@birthdayherobook.com

# Optional sender for the partner welcome email (sent when you add a partner in
# /admin). Falls back to ORDER_NOTIFICATION_FROM if unset. Any address on your
# verified Resend domain works — a friendlier default is shown below.
PARTNER_EMAIL_FROM="Birthday Hero Book <hello@birthdayherobook.com>"

# Server-only Stripe verification. Prefer a restricted key with read-only
# Checkout Sessions access. Use test values during testing and live values at launch.
STRIPE_RESTRICTED_KEY=rk_test_replace_with_your_read_only_checkout_sessions_key
STRIPE_STANDARD_PAYMENT_LINK_ID=plink_replace_with_standard_link_id
STRIPE_DELUXE_PAYMENT_LINK_ID=plink_replace_with_deluxe_link_id
STRIPE_FAMILY_PAYMENT_LINK_ID=plink_replace_with_family_link_id
STRIPE_WEBHOOK_SECRET=whsec_replace_when_the_webhook_is_connected

# Public Google Analytics 4 measurement ID (browser-exposed, so NEXT_PUBLIC_ is
# correct here). Analytics only loads after a visitor accepts analytics cookies.
# Leave blank to keep analytics disabled entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional salt for hashing referral-click IP addresses before storage (server
# only). If unset, IPs are still hashed, just without an extra salt.
REFERRAL_IP_SALT=replace-with-a-long-random-string

# --- Partner + admin portal (magic-link sign in) ---------------------------
# Supabase publishable (anon) key — used ONLY by the auth/session layer for the
# partner dashboard and admin. It is a public key by design, but every auth
# interaction here is server-rendered, so keep it server-only (no NEXT_PUBLIC_).
# Find it in Supabase → Project Settings → API keys (publishable / anon key).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace-with-your-anon-publishable-key

# Comma-separated admin emails allowed into /admin. Sign in via the same magic
# link; access unlocks only if your verified email is listed here.
ADMIN_EMAILS=you@example.com

# Also set the Supabase Auth redirect URLs (Supabase → Authentication → URL
# Configuration → Redirect URLs) so magic links can return to the site:
#   https://birthdayherobook.com/partners/auth/callback
#   http://localhost:3000/partners/auth/callback           (local dev)
#   https://*.vercel.app/partners/auth/callback            (Vercel previews)
